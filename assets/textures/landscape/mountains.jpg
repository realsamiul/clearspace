	<style>
	#loader {
	    position: fixed;
	    inset: 0;
	    background: black;
	    z-index: 1003;
	    transition: opacity 4s 0.6s linear;
	}
	
	#loader .logo,
	#loader .big-circle,
	#loader .omega,
	#loader .clearspace {
	    transition: opacity 0.6s linear;
	}
	
	#loader .big-circle {
	    position: absolute;
	    margin: auto;
	    inset: -100%;
	}
	
	#loader .big-circle {
	    transform-origin: center;
	    animation: rotating 2s linear infinite;
	}
	
	#loader .logo {
	    height: 25px;
	    opacity: 0;
	    transform: scale(0.5) rotate(-90deg);
	    transition: opacity 0.8s linear, transform 1s cubic-bezier(0.455, 0.03, 0.515, 0.955);
	}
	
	@media (min-width: 1024px) {
	    #loader .logo {
	        height: 35px;
	    }
	}
	
	#loader .logo .circle {
	    transform-origin: center;
	    animation: rotating 2s linear infinite;
	}
	
	@keyframes rotating {
	    from {
	        transform: rotate(0deg) scale(0.95);
	    }
	    to {
	        transform: rotate(360deg) scale(0.95);
	    }
	}
	
	#loader .big-circle {
	    width: 350px;
	}
	
	@media (min-width: 1024px) {
	    #loader .big-circle {
	        width: 563px;
	    }
	}
	
	#loader .clearspace,
	#loader .omega {
	    height: 12px;
	}
	
	@media (min-width: 1024px) {
	    #loader .clearspace,
	    #loader .omega {
	        height: 15px;
	    }
	}
	
	#loader .clearspace path,
	#loader .omega path {
	    opacity: 0;
	    transition: opacity 2s linear;
	}
	
	#loader .omega path:nth-child(1) {transition-delay: 0s;}
	#loader .omega path:nth-child(2) {transition-delay: 0.05s;}
	#loader .omega path:nth-child(3) {transition-delay: 0.1s;}
	#loader .omega path:nth-child(4) {transition-delay: 0.15s;}
	#loader .omega path:nth-child(5) {transition-delay: 0.2s;}
	
	#loader .clearspace path:nth-child(1) {transition-delay: 0.25s;}
	#loader .clearspace path:nth-child(2) {transition-delay: 0.3s;}
	#loader .clearspace path:nth-child(3) {transition-delay: 0.35s;}
	#loader .clearspace path:nth-child(4) {transition-delay: 0.4s;}
	#loader .clearspace path:nth-child(5) {transition-delay: 0.45s;}
	#loader .clearspace path:nth-child(6) {transition-delay: 0.5s;}
	#loader .clearspace path:nth-child(7) {transition-delay: 0.55s;}
	#loader .clearspace path:nth-child(8) {transition-delay: 0.6s;}
	#loader .clearspace path:nth-child(9) {transition-delay: 0.65s;}
	#loader .clearspace path:nth-child(10) {transition-delay: 0.7s;}
	
	#loader .clearspace {
	    top: 0;
	    bottom: 0;
	    margin: auto 0;
	    right: calc(50% + 24px);
	}
	
	@media (min-width: 1024px) {
	    #loader .clearspace {
	        right: calc(50% + 58px);
	    }
	}
	
	#loader .omega {
	    top: 0;
	    bottom: 0;
	    margin: auto 0;
	    left: calc(50% + 24px);
	}
	
	@media (min-width: 1024px) {
	    #loader .omega {
	        left: calc(50% + 58px);
	    }
	}
	
	#loader.loading .logo {
	    opacity: 1;
	    transform: scale(1) rotate(0deg);
	}
	
	#loader.loading .clearspace path,
	#loader.loading .omega path {
	    opacity: 1;
	}
	
	#loader.loaded {
	    pointer-events: none;
	    opacity: 0;
	}
	
	#loader.loaded .logo,
	#loader.loaded .big-circle,
	#loader.loaded .omega,
	#loader.loaded .clearspace {
	    opacity: 0;
	}
	
	
	#loader .loader-inside {
	    position: absolute;
	    inset: 0;
	    display: flex;
	    align-items: center;
	    justify-content: center;
	    gap: 25px;
	}
	
	</style>
